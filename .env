# APILeela — environment variables
# Copy this file to .env and adjust values for your environment.

# Server port
PORT=3000

# MongoDB connection string (default: standalone instance on 192.168.1.99)
# For Docker Compose, use: mongodb://mongo:27017/
MONGO_URL=mongodb://192.168.1.99:37017/

# MongoDB database name
MONGO_DB=apileela
